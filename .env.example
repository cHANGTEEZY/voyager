# Better Auth server root (no trailing slash).
# Copy to .env in the project root (not src/).
#
# Local dev (iOS simulator / web):
#   EXPO_PUBLIC_API_URL=http://localhost:3000
#
# Android emulator (auto-rewritten by get-api-url.ts, but you can set explicitly):
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
#
# Physical phone on same Wi‑Fi (use your computer's LAN IP):
#   EXPO_PUBLIC_API_URL=http://192.168.1.42:3000
EXPO_PUBLIC_API_URL=http://localhost:3000
